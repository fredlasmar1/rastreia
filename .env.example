# RASTREIA - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Banco de dados (Railway fornece automaticamente)
DATABASE_URL=postgresql://user:password@host:5432/rastreia

# JWT
JWT_SECRET=troque_por_uma_chave_secreta_longa_aqui

# Mercado Pago
MP_ACCESS_TOKEN=seu_access_token_mercado_pago
MP_WEBHOOK_SECRET=seu_webhook_secret

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_api_key
EVOLUTION_INSTANCE=rastreia

# Escavador API (processos judiciais estruturados)
# Contratar em: https://api.escavador.com
ESCAVADOR_API_KEY=sua_api_key_escavador

# Direct Data (CPF completo: endereço, telefone, email, renda)
# Cadastro grátis com R$50 de crédito: https://app.directd.com.br
DIRECTD_TOKEN=seu_token_directd

# CNPJá (CNPJ enriquecido: Simples Nacional, regime tributário, geolocalização)
# Gratuito para baixo volume, pago para alto volume: https://cnpja.com
CNPJA_API_KEY=sua_api_key_cnpja

# CPF.CNPJ (Receita Federal D+0 — fallback para CPF e CNPJ)
# Cadastro em: https://www.cpfcnpj.com.br | R$0,13-0,53/consulta
CPFCNPJ_API_KEY=seu_token_cpfcnpj

# Datajud CNJ (processos judiciais — 100% gratuito)
# Token opcional — sem ele usa a chave pública padrão
# Cadastro: https://datajud-wiki.cnj.jus.br/api-publica
DATAJUD_API_KEY=

# Portal da Transparência (CEIS/CNEP — listas negras federais — gratuito)
# Cadastro em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_TOKEN=seu_token_transparencia

# Serasa Experian (requer contrato empresarial — fase 2)
# Contratar em: https://www.serasaexperian.com.br/solucoes/api/
SERASA_API_KEY=

# Configurações do servidor
PORT=3000
NODE_ENV=production

# URL do sistema (Railway)
BASE_URL=https://rastreia.up.railway.app
